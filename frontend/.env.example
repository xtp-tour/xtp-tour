# Vite env variables (prefix with VITE_ to expose to client).
# Copy to .env.local or .env.development.local and fill in values.
# Never commit real secrets; use .env.*.local (gitignored) or CI env.

# API base URL. Empty in dev = use Vite proxy to /api
VITE_API_BASE_URL=

# Clerk publishable key (optional; empty = demo/mock mode)
VITE_CLERK_PUBLISHABLE_KEY=

# Google Analytics measurement ID (optional)
VITE_GA_MEASUREMENT_ID=

# App version for display (set by CI or make build-with-version)
VITE_APP_VERSION=
